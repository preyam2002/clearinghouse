{
  "name": "clearinghouse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "biome check .",
    "demo": "tsx scripts/demo.ts",
    "demo:mcp": "tsx scripts/demo-mcp.ts",
    "deploy": "tsx scripts/deploy.ts",
    "mcp": "pnpm --filter @clearinghouse/agents mcp",
    "preflight": "tsx scripts/preflight.ts",
    "test": "vitest run",
    "test:move": "MOVE_HOME=$PWD/.move-home sui move test --path move/clearinghouse"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.100.1",
    "@clearinghouse/agents": "workspace:*",
    "@clearinghouse/sdk": "workspace:*",
    "@mysten/sui": "2.17.0",
    "@noble/hashes": "1.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "latest",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
