# Required: the three live agents (code-gen, test-writer, reviewer) call Anthropic.
# scripts/demo.ts needs it in the shell; the dapp needs it in the server env (it
# powers the /api/run route). No key => the dapp's "Run agents" returns a clear 503.
ANTHROPIC_API_KEY=
SUI_NETWORK=localnet
PRIVATE_KEY_B64=
PACKAGE_ID=
REGISTRY_ID=
NEXT_PUBLIC_PACKAGE_ID=
NEXT_PUBLIC_REGISTRY_ID=
NEXT_PUBLIC_SUI_NETWORK=localnet
# Optional: override the default fullnode RPC URL for the SDK client
SUI_RPC_URL=
